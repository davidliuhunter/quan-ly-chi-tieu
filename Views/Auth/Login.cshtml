@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="min-h-screen flex items-center justify-center gradient-bg p-4">
    <div class="card-glass w-full max-w-sm">
        <div class="text-center mb-6">
            <div class="text-4xl mb-2">💰</div>
            <h1 class="text-xl font-bold text-gray-800 dark:text-gray-100">Quản Lý Chi Tiêu</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Đăng nhập để tiếp tục</p>
        </div>

        <form method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Mật khẩu</label>
                <input type="password" name="password" class="input-field" placeholder="Nhập mật khẩu..." autofocus />
            </div>

            @if (ViewBag.Error != null)
            {
                <p class="text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 px-3 py-2 rounded-lg">
                    @ViewBag.Error
                </p>
            }

            <button type="submit" class="bg-blue-600 text-white w-full px-4 py-2.5 rounded-xl font-medium hover:bg-blue-700 active:scale-95 transition-all">
                Đăng nhập
            </button>
        </form>
    </div>
</div>
