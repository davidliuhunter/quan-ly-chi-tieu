@model List<QuanLyChiTieu.Mvc.Controllers.BudgetStatusVm>
@{
    ViewData["Title"] = "Ngân sách";
    var categories = ViewBag.Categories as List<QuanLyChiTieu.Mvc.Models.Entities.DanhMuc>;
    var currentMonth = ViewBag.CurrentMonth as string;
}

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-800 dark:text-gray-100">🎯 Ngân sách tháng @currentMonth?.Substring(5)</h1>
        <button onclick="openForm()" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-blue-700 active:scale-95 transition-all">+ Thêm ngân sách</button>
    </div>

    <div class="space-y-3">
        @foreach (var b in Model)
        {
            var pct = b.Percentage;
            var barColor = pct > 100 ? "#ef4444" : pct > 80 ? "#f59e0b" : "#22c55e";
            <div class="card-glass">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                        <span>@b.CategoryIcon</span>
                        <span class="text-sm font-medium text-gray-800 dark:text-gray-200">@b.CategoryName</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-semibold @(pct > 100 ? "text-expense" : "text-income")">@b.SpentAmount.ToString("N0")₫ / @b.LimitAmount.ToString("N0")₫</span>
                        <form method="post" action="/NganSach/Delete" style="display:inline">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button type="button" class="btn-ghost btn-sm text-red-500" onclick="showConfirm('Xóa ngân sách này?',()=>this.form.submit())">🗑️</button>
                        </form>
                    </div>
                </div>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
                    <div class="h-3 rounded-full transition-all" style="width:@pct%;background:@barColor"></div>
                </div>
                <p class="text-xs text-gray-400 mt-1">@pct% đã chi tiêu</p>
            </div>
        }
        @if (Model.Count == 0)
        {
            <div class="text-center py-12 text-gray-400">
                <p class="text-4xl mb-2">📭</p>
                <p>Chưa có ngân sách nào cho tháng này</p>
            </div>
        }
    </div>
</div>

<div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="card-glass w-full max-w-sm mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-gray-800 dark:text-gray-100">Thêm ngân sách</h3>
            <button onclick="closeForm()" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
        </div>
        <form method="post" action="/NganSach/Create" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Danh mục</label>
                <select name="CategoryId" class="input-field" required>
                    <option value="">-- Chọn danh mục --</option>
                    @foreach (var c in categories ?? new())
                    {
                        <option value="@c.Id">@c.Icon @c.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tháng</label>
                <input name="Month" type="month" value="@currentMonth" class="input-field" required />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Hạn mức (VNĐ)</label>
                <input name="LimitAmount" type="number" class="input-field" placeholder="VD: 5000000" required min="1" />
            </div>
            <button type="submit" class="bg-blue-600 text-white w-full px-4 py-2.5 rounded-xl font-medium hover:bg-blue-700 active:scale-95 transition-all">Lưu</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openForm() { document.getElementById('modal').classList.remove('hidden'); document.getElementById('modal').classList.add('flex'); }
        function closeForm() { document.getElementById('modal').classList.add('hidden'); document.getElementById('modal').classList.remove('flex'); }
        document.getElementById('modal').addEventListener('click', function(e) { if (e.target === this) closeForm(); });
    </script>
}
